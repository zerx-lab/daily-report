# ============================================================
# 日报自动化系统 - Git 忽略规则
# ============================================================

# ---------- 数据目录（SQLite 数据库、日志等） ----------
data/

# ---------- 构建产物 ----------
build/
dist/

# ---------- 数据库文件 ----------
*.db
*.db-journal
*.db-shm
*.db-wal

# ---------- 日志文件 ----------
*.log

# ---------- 配置文件（含敏感信息，使用 config.yaml.example 作为模板） ----------
config/config.yaml

/server

# ---------- 环境变量文件 ----------
.env
.env.local
.env.production

# ---------- Go 相关 ----------
# 编译输出
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试覆盖率
*.out
*.test
coverage.html

# Go workspace
go.work
go.work.sum

# 依赖缓存（通常不提交 vendor）
# vendor/

# ---------- IDE / 编辑器 ----------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- MCP 配置（含本机绝对路径，不提交）----------
.mcp.json

# ---------- 临时文件 ----------
tmp/
temp/
*.tmp
*.bak
/mcp
